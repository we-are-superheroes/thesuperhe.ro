// =============================================================================
// Climate Collaboration Platform — Prisma Schema
// Stack: Next.js · PostgreSQL · Prisma ORM
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  member
  admin
}

// Two org types, one product surface. Type is a billing/vetting attribute
// set by the operator during approval — never a feature fork.
enum OrgType {
  nonprofit // free tier
  company   // paid tier
}

enum OrgStatus {
  pending   // request submitted, not yet approved by the operator
  active
  suspended // kill switch: page hidden from non-members, memberships frozen
}

enum OrgRole {
  owner
  admin
  member
}

enum Proficiency {
  beginner
  intermediate
  expert
}

enum ProjectStatus {
  defining
  needs_help
  in_progress
  completed
}

enum StepStatus {
  open
  defining
  in_progress
  needs_help
  completed
}

enum ContributionStatus {
  pending
  active
  completed
  withdrawn
}

enum ContributionRole {
  lead
  contributor
  advisor
  observer
}

enum UpdateVisibility {
  public   // Anyone browsing the project can read it.
  members  // Only active project members (and platform admins) can read it.
}

enum ProjectVisibility {
  public      // browsable by everyone
  org_members // visible to active members of the owning org only
}

enum ProjectJoinPolicy {
  open               // Anyone can join instantly.
  approval_required  // Joins land as `pending` Contributions; lead must accept.
  // Future values reserved (e.g. invite_only, member_referral) — adding new
  // ones is a column-free migration since the field is an enum.
}

// =============================================================================
// USERS
// =============================================================================

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String
  // Platform-level role. Source of truth for admin powers (delete any
  // project/blueprint). Set out-of-band (migration / DB), never from a
  // client request, and never touched by the Clerk webhook sync.
  role       UserRole @default(member)
  avatarUrl  String?  @map("avatar_url")
  bio        String?
  location   String?
  timezone   String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Presence ping — bumped by the platform layout on every fetch so we can
  // surface "Online" indicators (last seen within ~5 minutes).
  lastSeenAt DateTime? @map("last_seen_at")

  skills          UserSkill[]
  organisations   UserOrganisation[]
  contributions   Contribution[]
  blueprints      Blueprint[]
  coordinatedSteps ProjectStep[]     @relation("CoordinatedSteps")
  timeLogs         TimeLog[]
  notifications   Notification[]     @relation("UserNotifications")
  actedNotifications Notification[]  @relation("ActorNotifications")
  conversations   ConversationParticipant[]
  messagesSent    Message[]          @relation("MessageSender")
  projectUpdates  ProjectUpdate[]    @relation("UpdateAuthor")
  orgInvitesCreated OrganisationInvite[] @relation("InvitesCreated")

  @@map("users")
}

// =============================================================================
// SKILLS
// =============================================================================

model Skill {
  id          String  @id @default(uuid())
  name        String  @unique
  category    String
  description String?

  userSkills  UserSkill[]
  stepSkills  StepSkill[]

  @@map("skills")
}

// Junction: users ↔ skills
model UserSkill {
  userId    String   @map("user_id")
  skillId   String   @map("skill_id")

  proficiency Proficiency
  isSeeking   Boolean  @default(true) @map("is_seeking")
  createdAt   DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@map("user_skills")
}

// =============================================================================
// ORGANISATIONS
// =============================================================================

// Created `pending` by the request form; the operator approves (→ active)
// and sets `type` out-of-band. No self-serve creation. Deleting an org that
// owns projects fails at the DB (FK has no cascade) — suspend instead.
model Organisation {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  type        OrgType
  status      OrgStatus @default(pending)
  description String?
  logoUrl     String?   @map("logo_url")
  bannerUrl   String?   @map("banner_url")
  website     String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  members  UserOrganisation[]
  invites  OrganisationInvite[]
  projects Project[]

  @@map("organisations")
}

// Junction: users ↔ organisations. One row per (user, org): leaving sets
// leftAt (soft leave — historical hours stay in org aggregates); re-joining
// reactivates the row with joinedAt reset.
model UserOrganisation {
  userId String @map("user_id")
  orgId  String @map("org_id")

  role     OrgRole
  // Whether this member's contributions to non-org public projects count in
  // this org's aggregates and exports. Own-project hours always count.
  shareContributions Boolean @default(true) @map("share_contributions")
  joinedAt DateTime  @default(now()) @map("joined_at")
  leftAt   DateTime? @map("left_at")

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([userId, orgId])
  @@index([userId, leftAt])
  @@index([orgId, leftAt])
  @@map("user_organisations")
}

// Invite codes. email null = open shareable code; email set = targeted
// invite for that address (delivered in-app for MVP; Resend later).
model OrganisationInvite {
  id          String    @id @default(uuid())
  orgId       String    @map("org_id")
  code        String    @unique
  email       String?
  invitedById String    @map("invited_by_id")
  maxUses     Int?      @map("max_uses") // null = unlimited within expiry
  useCount    Int       @default(0) @map("use_count")
  expiresAt   DateTime? @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  org       Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedBy User         @relation("InvitesCreated", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("organisation_invites")
}

// =============================================================================
// PROJECT TYPES
// =============================================================================

model ProjectType {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  icon        String?

  blueprints Blueprint[]
  projects   Project[]

  @@map("project_types")
}

// =============================================================================
// BLUEPRINTS
// =============================================================================

model Blueprint {
  id            String   @id @default(uuid())
  createdById   String   @map("created_by")
  projectTypeId String?  @map("project_type_id")
  // Parent of a variant blueprint. Self-FK; null on family roots. A child
  // can't itself have children (one level deep — enforced server-side).
  parentBlueprintId String? @map("parent_blueprint_id")

  title        String
  description  String
  // ISO 639-1 language code (e.g. "en", "de") + ISO 3166-1 alpha-2 country
  // code (e.g. "GB", "CH"). Optional on roots; required on children.
  language     String?
  country      String?
  estimatedHrs Int?     @map("estimated_hrs")
  reuseCount   Int      @default(0) @map("reuse_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  createdBy   User         @relation(fields: [createdById], references: [id])
  projectType ProjectType? @relation(fields: [projectTypeId], references: [id])
  parent      Blueprint?   @relation("BlueprintVariants", fields: [parentBlueprintId], references: [id], onDelete: SetNull)
  variants    Blueprint[]  @relation("BlueprintVariants")
  steps       BlueprintStep[]
  projects    Project[]

  @@index([parentBlueprintId])
  @@index([country])
  @@index([language])
  @@map("blueprints")
}

model BlueprintStep {
  id          String @id @default(uuid())
  blueprintId String @map("blueprint_id")

  title         String
  description   String?
  order         Int
  estimatedHrs  Int?       @map("estimated_hrs")
  statusDefault StepStatus @default(open) @map("status_default")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  blueprint    Blueprint     @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  skills       StepSkill[]
  projectSteps ProjectStep[]

  @@map("blueprint_steps")
}

// =============================================================================
// PROJECTS
// =============================================================================

model Project {
  id            String  @id @default(uuid())
  orgId         String? @map("organisation_id")
  blueprintId   String? @map("blueprint_id")
  projectTypeId String? @map("project_type_id")

  title                 String
  description           String
  status                ProjectStatus @default(defining)
  // Coarse "City, Country" for browse-page filters.
  location              String?
  // Precise location (optional): a human-readable address or place name,
  // used (with `location`) to build the "Open in Google Maps" link on the
  // project page. NB: legacy latitude/longitude columns still exist in the
  // DB until the follow-up drop migration lands (contract phase).
  address               String?
  // ISO codes for browse-page filters. Pre-filled from the source blueprint
  // when a project is forked, editable from the project form.
  language              String?
  country               String?
  remoteOk              Boolean  @default(true) @map("remote_ok")
  // org_members requires orgId (DB CHECK projects_org_visibility_check).
  // Every read path for org_members projects must verify active membership.
  visibility            ProjectVisibility @default(public)
  timeCommitmentHrs     Int?     @map("time_commitment_hrs")
  coverImageUrl         String?  @map("cover_image_url")
  joinPolicy            ProjectJoinPolicy @default(open) @map("join_policy")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  organisation  Organisation? @relation(fields: [orgId], references: [id])
  blueprint     Blueprint?    @relation(fields: [blueprintId], references: [id])
  projectType   ProjectType?  @relation(fields: [projectTypeId], references: [id])
  steps         ProjectStep[]
  contributions Contribution[]
  notifications Notification[]
  updates       ProjectUpdate[]

  @@index([country])
  @@index([language])
  @@index([orgId, visibility])
  @@map("projects")
}

// Lead-authored updates shown in the project's Updates tab. Public posts are
// readable by anyone browsing the project; members-only posts require an
// active contribution (platform admins can also read them, for moderation).
model ProjectUpdate {
  id        String  @id @default(uuid())
  projectId String  @map("project_id")
  // SetNull on author deletion: the update is project history and survives,
  // rendered as "Former member" (same pattern as Message.senderId).
  authorId  String? @map("author_id")

  body       String
  visibility UpdateVisibility @default(members)
  createdAt  DateTime  @default(now()) @map("created_at")
  editedAt   DateTime? @map("edited_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User?   @relation("UpdateAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt(sort: Desc)])
  @@map("project_updates")
}

// Live steps on a specific project.
// blueprintStepId traces origin when instantiated from a blueprint; null if ad hoc.
model ProjectStep {
  id              String  @id @default(uuid())
  projectId       String  @map("project_id")
  blueprintStepId String? @map("blueprint_step_id")
  // Coordinator — single user the project lead designates as the point of
  // contact for this step. The actual joiners are tracked many-to-many via
  // Contribution(projectStepId). Auto-set to the first joiner; project leads
  // can reassign from /modify.
  coordinatorId   String? @map("coordinator_id")

  title        String
  description  String?
  order        Int
  estimatedHrs Int?       @map("estimated_hrs")
  status       StepStatus @default(open)
  dueDate      DateTime?  @map("due_date")
  completedAt  DateTime?  @map("completed_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  blueprintStep BlueprintStep? @relation(fields: [blueprintStepId], references: [id])
  coordinator   User?          @relation("CoordinatedSteps", fields: [coordinatorId], references: [id])
  skills        StepSkill[]
  contributions Contribution[]
  timeLogs      TimeLog[]

  @@map("project_steps")
}

// =============================================================================
// STEP SKILLS
// Exactly one of blueprintStepId or projectStepId will be non-null.
// =============================================================================

model StepSkill {
  id              String  @id @default(uuid())
  skillId         String  @map("skill_id")
  blueprintStepId String? @map("blueprint_step_id")
  projectStepId   String? @map("project_step_id")

  context String?

  skill         Skill          @relation(fields: [skillId], references: [id], onDelete: Cascade)
  blueprintStep BlueprintStep? @relation(fields: [blueprintStepId], references: [id], onDelete: Cascade)
  projectStep   ProjectStep?   @relation(fields: [projectStepId], references: [id], onDelete: Cascade)

  @@map("step_skills")
}

// =============================================================================
// CONTRIBUTIONS
// =============================================================================

model Contribution {
  id            String  @id @default(uuid())
  userId        String  @map("user_id")
  projectId     String  @map("project_id")
  projectStepId String? @map("project_step_id")

  role             ContributionRole
  status           ContributionStatus @default(pending)
  hoursContributed Float              @default(0) @map("hours_contributed")
  joinedAt         DateTime           @default(now()) @map("joined_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectStep ProjectStep? @relation(fields: [projectStepId], references: [id], onDelete: Cascade)

  // NB: Postgres treats NULLs as distinct here, so this composite unique
  // never guards project-level rows (projectStepId NULL). Those are covered
  // by a partial unique index (contributions_project_level_unique) created
  // in raw SQL — Prisma can't express partial indexes in the schema.
  @@unique([userId, projectId, projectStepId])
  @@index([userId, projectId])
  @@map("contributions")
}

// =============================================================================
// TIME LOGS
// Per-entry hours logged against a step. Sum is denormalised onto
// Contribution.hoursContributed for cheap dashboard reads; the action layer
// keeps the two in sync inside a transaction.
// =============================================================================

model TimeLog {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  projectStepId String   @map("project_step_id")

  hours    Float
  note     String?
  loggedOn DateTime @default(now()) @map("logged_on")
  createdAt DateTime @default(now()) @map("created_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectStep ProjectStep @relation(fields: [projectStepId], references: [id], onDelete: Cascade)

  @@index([userId, loggedOn(sort: Desc)])
  @@index([projectStepId, loggedOn(sort: Desc)])
  @@map("time_logs")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

enum NotificationType {
  project_join
  project_join_request
  project_leave
  project_updated
  project_status_changed
  step_claimed
  step_unclaimed
  step_completed
  step_needs_help
  step_assigned
  blueprint_forked
  skill_match
  reminder_step_idle
  // Reserved for later; schema accommodates them now.
  message_received
  mention
  invite_received
  project_milestone
  welcome
}

model Notification {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  type        NotificationType

  // Soft references — SetNull so notifications outlive deletions.
  actorId     String?  @map("actor_id")
  projectId   String?  @map("project_id")
  stepId      String?  @map("step_id")
  blueprintId String?  @map("blueprint_id")

  // Snapshot copy at write time so the inbox renders without joins.
  title       String
  body        String?
  data        Json?

  readAt      DateTime? @map("read_at")
  emailedAt   DateTime? @map("emailed_at")
  resolvedAt  DateTime? @map("resolved_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user    User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actor   User?    @relation("ActorNotifications", fields: [actorId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@map("notifications")
}

// =============================================================================
// MESSAGING
// =============================================================================

model Conversation {
  id              String   @id @default(uuid())
  // ":"-joined sorted user ids for 1-to-1 conversations. Lets a single
  // upsert do find-or-create. Null for future group conversations.
  participantsKey String?  @unique @map("participants_key")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt(sort: Desc)])
  @@map("conversations")
}

model ConversationParticipant {
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")

  joinedAt    DateTime  @default(now()) @map("joined_at")
  // unread = messages.createdAt > lastReadAt (or lastReadAt IS NULL)
  lastReadAt  DateTime? @map("last_read_at")
  mutedAt     DateTime? @map("muted_at")
  archivedAt  DateTime? @map("archived_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId, archivedAt])
  @@map("conversation_participants")
}

model Message {
  id             String    @id @default(uuid())
  conversationId String    @map("conversation_id")
  // SetNull on sender deletion: the message survives, renders as "Deleted user".
  senderId       String?   @map("sender_id")
  body           String
  createdAt      DateTime  @default(now()) @map("created_at")
  editedAt       DateTime? @map("edited_at")
  // Soft delete: the message stays but renders as "[deleted]" to all viewers.
  deletedAt      DateTime? @map("deleted_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation("MessageSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}
