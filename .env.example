# =============================================================================
# Environment variables for The Superhero
#
# Copy to `.env.local` for local dev and fill in. In Vercel, set these per
# environment scope (Production vs Preview) — see DEPLOYMENT.md. Never commit
# real values; this template lists NAMES only.
# =============================================================================

# --- Database (Supabase Postgres) -------------------------------------------
# Runtime uses the POOLED connection (PgBouncer, port 6543). Append
# ?pgbouncer=true. Use the matching project's URL per environment.
DATABASE_URL=

# Optional: DIRECT connection (port 5432), only needed for `prisma migrate dev`
# locally. The migration runner (npm run db:apply) uses DATABASE_URL.
DIRECT_URL=

# --- Clerk (auth) ------------------------------------------------------------
# Development instance keys (pk_test…/sk_test…) for local + Preview.
# Production instance keys (pk_live…/sk_live…) go in the Vercel Production scope.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk webhook signing secret (one per Clerk instance → per Vercel scope).
# Endpoint: <site-url>/api/webhooks/clerk
CLERK_WEBHOOK_SECRET=

# Auth route paths (same across environments).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# --- Supabase Storage (avatars + project covers) ----------------------------
# Project URL, e.g. https://<ref>.supabase.co — next.config.ts derives the
# allowed next/image host from this at build time.
NEXT_PUBLIC_SUPABASE_URL=
# Server-only service_role key (full storage access). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Resend) — not wired up yet; placeholder for future use ----------
RESEND_API_KEY=
